{
  "name": "digital-affiliate-manager",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "trap 'kill 0' EXIT; npx tailwindcss -i ./src/input.css -o ./public/css/main.css --minify --watch & bun run --watch src/index.tsx",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./public/css/main.css --minify",
    "start": "bun run src/index.tsx"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
